generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  ARCHIVED
}

enum ServiceType {
  STUDENT_RESIDENCE
  HOUSING
  UNIVERSITY_SELECTION
  AUSBILDUNG
  TURKEY_RESIDENCE
  OTHER
}

enum EvaluationStatus {
  NEW
  REVIEWING
  CONTACTED
  CLOSED
}

enum ApplicationType {
  STUDENT_GERMANY
  STUDENT_TURKEY
  AUSBILDUNG
  OTHER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum DocumentCategory {
  PASSPORT
  DIPLOMA
  TRANSCRIPT
  LANGUAGE_CERTIFICATE
  PHOTO
  FINANCIAL_PROOF
  RESUME
  MOTIVATION_LETTER
  ACCEPTANCE_LETTER
  INSURANCE
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  phone         String?
  role          Role     @default(USER)
  emailVerified DateTime?

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews          Review[]
  contactRequests  ContactRequest[]
  evaluations      Evaluation[]
  applications     Application[]
  documents        Document[]
  sessions         Session[]
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  type      ApplicationType   @default(STUDENT_GERMANY)
  status    ApplicationStatus @default(DRAFT)
  title     String
  adminNotes String?          @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([userId])
  @@index([status])
}

model Document {
  id            String           @id @default(cuid())
  userId        String
  applicationId String?
  category      DocumentCategory @default(OTHER)
  status        DocumentStatus   @default(PENDING)
  originalName  String
  storedName    String
  mimeType      String
  size          Int
  reviewNote    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([applicationId])
  @@index([status])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String       @id @default(cuid())
  userId    String?
  authorName String
  authorEmail String?
  rating    Int
  title     String?
  content   String       @db.Text
  status    ReviewStatus @default(PENDING)
  serviceType ServiceType?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model ContactRequest {
  id          String        @id @default(cuid())
  userId      String?
  fullName    String
  email       String
  phone       String?
  serviceType ServiceType?
  subject     String?
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  adminNotes  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Evaluation {
  id        String           @id @default(cuid())
  userId    String?
  status    EvaluationStatus @default(NEW)

  // مشخصات فردی
  fullName        String
  gender          String?
  maritalStatus   String?
  birthDate       String?
  militaryStatus  String?
  hasChildUnder18 Boolean @default(false)

  // مشخصات تماس
  mobile   String
  phone    String?
  email    String
  province String?

  // دانش زبان
  germanLevel String?
  hasIelts    Boolean @default(false)
  ieltsScore  String?
  hasToefl    Boolean @default(false)
  toeflScore  String?

  // سوابق تحصیلی
  diplomaField      String?
  diplomaGpa        String?
  lastDegree        String?
  bachelorUniversity String?
  bachelorField     String?
  bachelorGpa       String?

  // دانشگاه و رشته مورد نظر (آلمان)
  targetDegree      String?
  targetField       String?
  targetUniversity  String?
  targetPreferences Json?

  // سوابق شغلی
  jobTitle             String?
  workExperienceYears  String?
  currentlyEmployed    Boolean @default(false)

  // اطلاعات تکمیلی
  howFoundUs   String?
  referralCode String?
  description  String? @db.Text

  adminNotes String? @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id         String    @id @default(cuid())
  identifier String // email
  tokenHash  String    @unique
  type       TokenType
  expires    DateTime
  createdAt  DateTime  @default(now())

  @@index([identifier])
}

model SiteSettings {
  id              Int      @id @default(1)
  heroTitleFa     String?
  heroTitleTr     String?
  heroTitleDe     String?
  heroSubtitleFa  String?  @db.Text
  heroSubtitleTr  String?  @db.Text
  heroSubtitleDe  String?  @db.Text
  contactPhone    String?
  contactEmail    String?
  contactAddress  String?
  whatsappNumber  String?
  telegramHandle  String?
  instagramHandle String?
  updatedAt       DateTime @updatedAt
}
