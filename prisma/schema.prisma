generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  ANSWERED
  ARCHIVED
}

enum ServiceType {
  STUDENT_RESIDENCE
  HOUSING
  UNIVERSITY_SELECTION
  AUSBILDUNG
  TURKEY_RESIDENCE
  OTHER
}

enum EvaluationStatus {
  NEW
  REVIEWING
  CONTACTED
  CLOSED
}

enum ApplicationType {
  STUDENT_GERMANY
  STUDENT_TURKEY
  AUSBILDUNG
  OTHER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum DocumentCategory {
  PASSPORT
  DIPLOMA
  TRANSCRIPT
  LANGUAGE_CERTIFICATE
  PHOTO
  FINANCIAL_PROOF
  RESUME
  MOTIVATION_LETTER
  ACCEPTANCE_LETTER
  INSURANCE
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

// Phase-5 §workspace — per-task status. Admin-tick = canonical DONE
// (PHASE-5-PLAN §2.2). PENDING and IN_PROGRESS are the working states;
// BLOCKED is for admin to flag dependencies the student can't resolve.
enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

// Phase-5 §workspace — task category, used for grouping + icon picking
// in the UI. Mirrors the documented Turkey-preparation steps.
enum TaskCategory {
  UNIVERSITY_REGISTRATION
  RESIDENCE_PERMIT
  HEALTH_INSURANCE
  BANK_ACCOUNT
  SPERRKONTO
  MONEY_TRANSFER
  DOCUMENT_TRANSLATION
  EMBASSY_APPOINTMENT
  OTHER
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  phone         String?
  role          Role     @default(USER)
  emailVerified DateTime?

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Phase-4 §5 — marketing email opt-in. Defaulted FALSE so silence
  // is opt-OUT (GDPR-safe). marketingConsentAt is set the moment the
  // user toggles it on; cleared when they unsubscribe via the signed
  // token endpoint.
  marketingConsent    Boolean   @default(false)
  marketingConsentAt  DateTime?

  // Phase-5 §workspace — opt into a daily digest instead of per-event
  // notification emails. Column lands now so the future digest worker
  // has its preference home; the rate-limit cap (5/student/day/case)
  // covers the noisy-email case in the meantime.
  notificationDailyDigest Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews          Review[]
  contactRequests  ContactRequest[]
  evaluations      Evaluation[]
  applications     Application[]
  documents        Document[]
  sessions         Session[]
  tasksStudentTicked Task[] @relation("StudentTickedTasks")
  tasksAdminTicked   Task[] @relation("AdminTickedTasks")
  posts            Post[]
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  type      ApplicationType   @default(STUDENT_GERMANY)
  status    ApplicationStatus @default(DRAFT)
  title     String
  adminNotes String?          @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Phase-4 — last time the owner pushed adminNotes to the lead by email.
  lastNotifiedAt DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  tasks     Task[]

  @@index([userId])
  @@index([status])
}

model Document {
  id            String           @id @default(cuid())
  userId        String
  applicationId String?
  category      DocumentCategory @default(OTHER)
  status        DocumentStatus   @default(PENDING)
  originalName  String
  storedName    String
  mimeType      String
  size          Int
  reviewNote    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([applicationId])
  @@index([status])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String       @id @default(cuid())
  userId    String?
  authorName String
  authorEmail String?
  rating    Int
  title     String?
  content   String       @db.Text
  status    ReviewStatus @default(PENDING)
  serviceType ServiceType?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model ContactRequest {
  id          String        @id @default(cuid())
  userId      String?
  fullName    String
  email       String
  phone       String?
  serviceType ServiceType?
  subject     String?
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  adminNotes  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Consent record (LEGAL-04). All nullable — old rows stay NULL.
  consentAcceptedAt   DateTime?
  consentTermsVersion Int?
  consentIp           String?
  consentUserAgent    String?
  marketingConsent    Boolean?

  // TRUST-10 — explicit acknowledgement that German-side outcomes
  // (embassy, university, exam-center decisions) are out of Almanyar's
  // control. Required on new submissions; nullable so historical rows
  // stay valid.
  germanyRiskAcknowledged   Boolean?
  germanyRiskAcknowledgedAt DateTime?

  // Phase-4 — last time the owner pushed adminNotes to the lead by email.
  lastNotifiedAt DateTime?

  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Evaluation {
  id        String           @id @default(cuid())
  userId    String?
  status    EvaluationStatus @default(NEW)

  // مشخصات فردی
  fullName        String
  gender          String?
  maritalStatus   String?
  birthDate       String?
  militaryStatus  String?
  hasChildUnder18 Boolean @default(false)

  // مشخصات تماس
  mobile   String
  phone    String?
  email    String
  province String?

  // دانش زبان
  germanLevel String?
  hasIelts    Boolean @default(false)
  ieltsScore  String?
  hasToefl    Boolean @default(false)
  toeflScore  String?

  // سوابق تحصیلی
  diplomaField      String?
  diplomaGpa        String?
  lastDegree        String?
  bachelorUniversity String?
  bachelorField     String?
  bachelorGpa       String?

  // دانشگاه و رشته مورد نظر (آلمان)
  targetDegree      String?
  targetField       String?
  targetUniversity  String?
  targetPreferences Json?

  // سوابق شغلی
  jobTitle             String?
  workExperienceYears  String?
  currentlyEmployed    Boolean @default(false)

  // اطلاعات تکمیلی
  howFoundUs   String?
  referralCode String?
  description  String? @db.Text

  adminNotes String? @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Consent record (LEGAL-04). All nullable — old rows stay NULL.
  consentAcceptedAt   DateTime?
  consentTermsVersion Int?
  consentIp           String?
  consentUserAgent    String?
  marketingConsent    Boolean?

  // TRUST-10 — explicit acknowledgement that German-side outcomes
  // (embassy, university, exam-center decisions) are out of Almanyar's
  // control. Required on new submissions; nullable so historical rows
  // stay valid.
  germanyRiskAcknowledged   Boolean?
  germanyRiskAcknowledgedAt DateTime?

  // Phase-4 — last time the owner pushed adminNotes to the lead by email.
  lastNotifiedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id         String    @id @default(cuid())
  identifier String // email
  tokenHash  String    @unique
  type       TokenType
  expires    DateTime
  createdAt  DateTime  @default(now())

  @@index([identifier])
}

model SiteSettings {
  id              Int      @id @default(1)
  heroTitleFa     String?
  heroTitleTr     String?
  heroTitleDe     String?
  heroSubtitleFa  String?  @db.Text
  heroSubtitleTr  String?  @db.Text
  heroSubtitleDe  String?  @db.Text
  contactPhone    String?
  contactEmail    String?
  contactAddress  String?
  whatsappNumber  String?
  telegramHandle  String?
  instagramHandle String?
  updatedAt       DateTime @updatedAt
}

// Editable homepage hero stats. Singleton (id = 1). NULL means "not yet
// counted" — the frontend hides the corresponding card / block rather than
// showing a literal zero. See BUG-03.
// reviewsCount and averageRating are a manual override; if there are any
// APPROVED reviews in the Review table, the live aggregate wins.
model SiteStats {
  id                   Int      @id @default(1)
  studentsCount        Int?
  partnerUniversities  Int?
  successRate          Int?
  yearsExperience      Int?
  averageRating        Float?
  reviewsCount         Int?
  updatedAt            DateTime @updatedAt
}

// Phase-4 §4 — every customer-facing email sent from /admin pages
// (notify-customer button) writes a row here so the owner has an
// auditable trail of what was sent, to whom, and when.
enum AdminEmailLeadType {
  CONTACT
  EVALUATION
  APPLICATION
}

model AdminEmailLog {
  id        String              @id @default(cuid())
  leadType  AdminEmailLeadType
  leadId    String
  to        String
  subject   String
  snippet   String              @db.Text
  sentBy    String?
  sentAt    DateTime            @default(now())

  @@index([leadType, leadId])
  @@index([sentAt])
}

// Phase-5 §workspace — a single step in an Application's roadmap.
//
// Brief §۵: «چک‌لیست شخصی‌سازی‌شده توسط ادمین برای هر کاربر». The owner
// builds a sequence of tasks per Application; the student sees them
// in `order asc`, ticks "I did it" (studentTicked), and the owner
// confirms (adminTicked → status=DONE).
//
// `requiredDocCategory` optionally binds a task to a Document upload:
// when the student uploads a Document of the named category linked to
// the same Application, the UI surfaces it on the task; admin still
// has to mark the task DONE explicitly.
model Task {
  id            String       @id @default(cuid())
  applicationId String
  order         Int
  title         String
  description   String?      @db.Text
  category      TaskCategory @default(OTHER)
  status        TaskStatus   @default(PENDING)

  // Optional binding: if set, the student is expected to upload a
  // Document of this category to complete the task. UI shows progress.
  requiredDocCategory DocumentCategory?

  // Two-way ticking (PHASE-5-PLAN §2.2). studentTicked is informational;
  // admin's tick is what flips status=DONE in the service layer.
  studentTicked    Boolean   @default(false)
  studentTickedAt  DateTime?
  studentTickedById String?

  adminTicked      Boolean   @default(false)
  adminTickedAt    DateTime?
  adminTickedById  String?

  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  studentTickedBy  User?       @relation("StudentTickedTasks", fields: [studentTickedById], references: [id], onDelete: SetNull)
  adminTickedBy    User?       @relation("AdminTickedTasks",   fields: [adminTickedById],   references: [id], onDelete: SetNull)

  @@index([applicationId, order])
  @@index([status])
}

// Phase-5 §workspace — lightweight rate-limit ledger for student-facing
// notification emails. Cap is currently 5 / userId / kind / 24h, enforced
// at the call site in lib/notify.ts. A simple table is fine for the
// volume we expect; we can swap to Redis later without changing the API.
model EmailRateLimit {
  id     String   @id @default(cuid())
  userId String
  kind   String
  sentAt DateTime @default(now())

  @@index([userId, kind, sentAt])
}

// Phase-8 §CMS — news/articles published from the admin panel.
//
// Topics (`src/lib/topic-content/`) and Posts are TWO content layers:
//   - Topics  = evergreen authority pages, code-shaped TS files, ~35
//               existing entries, not in DB
//   - Posts   = time-ordered news/updates, admin-editable via TipTap,
//               render at /fa/news/<slug>
//
// `bodyJson` is the source of truth (TipTap can re-edit it precisely);
// `bodyHtml` is pre-rendered for fast public reads.
enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Post {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  // Optional SEO override; if null the public page falls back to `title`.
  seoTitle        String?
  metaDescription String?      @db.Text
  // 1-2 sentence summary for feed cards.
  excerpt         String?      @db.Text
  // TipTap-rendered HTML for fast SSR.
  bodyHtml        String       @db.Text
  // TipTap JSON snapshot — re-edit fidelity.
  bodyJson        Json?
  coverImageUrl   String?
  coverImageAlt   String?
  status          PostStatus   @default(DRAFT)
  // Stamped the first time status flips to PUBLISHED; not cleared on
  // unpublish (so a re-publish keeps the original publish date for SEO).
  publishedAt     DateTime?
  authorId        String?
  categoryId      String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  author    User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category  PostCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tags      PostsOnTags[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([slug])
}

model PostCategory {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  // Display order in the admin/category-list UI. Lower = first.
  order Int    @default(0)
  posts Post[]
}

model PostTag {
  id    String        @id @default(cuid())
  slug  String        @unique
  name  String
  posts PostsOnTags[]
}

// Explicit M2M join table — gives us a stable composite PK and clean
// cascade semantics (delete a Post → its tag links go too; delete a
// Tag → its post links go too; neither side orphans).
model PostsOnTags {
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
  @@index([tagId])
}
