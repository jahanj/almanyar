# Local development environment.
# Copy to `.env` and fill in values. For production, see `.env.production.example`.

# --- Database ---
DATABASE_URL="postgresql://germanbiz:password@localhost:5432/germanbiz?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- Admin bootstrap (used by the seed script) ---
ADMIN_EMAIL="admin@example.local"
ADMIN_PASSWORD="change-me-after-first-login"

# --- SMTP (optional — leave blank to log emails instead of sending) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AlmanYar <noreply@example.local>"
# Where new contact-request notifications go.
ADMIN_NOTIFY_EMAIL="admin@example.local"

# --- Marketing email (Phase 4) ---
# HMAC for signed unsubscribe tokens. Falls back to NEXTAUTH_SECRET if unset.
MARKETING_TOKEN_SECRET=""

# --- Site canonical / SEO ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Anything other than "production" makes /robots.txt emit Disallow: / (safe for staging/dev).
APP_ENV="development"

# --- App ---
NODE_ENV="development"
