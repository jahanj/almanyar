# Database
DATABASE_URL="postgresql://germanbiz:password@localhost:5432/germanbiz?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin bootstrap (used by seed script)
ADMIN_EMAIL="admin@germanbiz.com"
ADMIN_PASSWORD="ChangeThisStrongPassword123!"

# SMTP for sending emails (contact form notifications)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="مهاجرت آلمان <noreply@yourdomain.com>"
ADMIN_NOTIFY_EMAIL="admin@yourdomain.com"

# App
NODE_ENV="development"
