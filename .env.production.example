# ───────────────────────────────────────────────────────────────
# Production environment template for VPS + Docker deployment.
#
# Copy this file to `.env` on the server, then fill in every
# `__REPLACE_ME__` value:
#
#     cp .env.production.example .env && nano .env
#
# Generate strong random secrets with:
#     openssl rand -base64 32
#
# NEVER commit the real .env to git.
# ───────────────────────────────────────────────────────────────

# --- Database ---
# Used by docker-compose to create the Postgres container AND build DATABASE_URL.
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=__REPLACE_ME__

# --- App URL & auth ---
# Your real domain (with https).
NEXTAUTH_URL=https://YOURDOMAIN.com
# Required for NextAuth session signing. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=__REPLACE_ME__

# --- Admin bootstrap (used once by the seed script) ---
ADMIN_EMAIL=admin@YOURDOMAIN.com
# Strong password — change it after first login.
# Generate with: openssl rand -base64 24
ADMIN_PASSWORD=__REPLACE_ME__

# --- SMTP (transactional email: verification, password reset, contact) ---
# Fill from your provider (Brevo, Mailgun, Resend SMTP, etc.).
# If left blank the app still runs, but emails are skipped (logged only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=YourBrand <noreply@YOURDOMAIN.com>
# Where new contact-request notifications are sent.
ADMIN_NOTIFY_EMAIL=admin@YOURDOMAIN.com

# --- Marketing email (Phase 4) ---
# HMAC key for signed unsubscribe tokens. Falls back to NEXTAUTH_SECRET
# if unset, but set explicitly so rotating one doesn't invalidate the other.
# Generate with: openssl rand -base64 32
MARKETING_TOKEN_SECRET=__REPLACE_ME__

# --- Site canonical / SEO ---
# Used by next/metadata for canonical URLs, og:url, sitemap absolute hrefs.
NEXT_PUBLIC_SITE_URL=https://YOURDOMAIN.com
# Set to "production" so /robots.txt allows indexing.
# Anything else → robots.txt emits Disallow: / (staging safety).
APP_ENV=production

# --- App ---
NODE_ENV=production
